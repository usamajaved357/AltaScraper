# ============================================================
#  Keep secrets and machine-specific files OUT of git.
#  If you ever run `git init` in this folder, these are ignored.
# ============================================================

# --- Secrets / credentials (NEVER commit these) ---
service_account.json
config.json
# backups/variants of config.json (e.g. *.pre-zip-import.bak)
config.json*
*.pem
*.key
.env
# App backup archives -- these bundle a full config.json with LIVE credentials, so a
# zip of the app must NEVER be committed. (e.g. "new app for brands shopify to amazon.zip")
*.zip

# --- Local data caches / runtime state (machine-specific, per CLAUDE.md §2 — never commit) ---
# These are written at runtime (they live on the persistent disk on the server), so they
# change every time the app runs -- they are app STATE, not code / bug fixes.
miles_bundles_store.json
miles_bundles.json
miles_harvested.json
miles_items.json
miles_ui_prefs.json
model_number_counter.json
attribute_defaults.json

# --- Session baselines (bug-check snapshots, per CLAUDE.md §3 — never commit) ---
*.baseline.py

# --- Runtime / machine-specific ---
.venv/
.app_port
.DS_Store

# --- Python caches ---
__pycache__/
*.py[cod]
*.egg-info/

# --- Generated output folders (runtime; these become persistent-disk mounts on the server) ---
media/
uploads/
inventory_out/
ppc_out/
brands/
miles_templates/
files/
autofix_logs/
filled_unified_template.xlsm

# --- Stray local artifacts, not part of the app ---
python-3.14.6-macos11.pkg
KITCHEN_COOKWARE_SET_FOOD_SPATULA_KITCHEN_KNIFE_HARDWARE__2_.xlsm
