{
  "_meta": {
    "version": "1.1",
    "purpose": "Universal IP/trademark compliance for Amazon UK dropshipping listings",
    "note": "Approach: zero brand names except seller's own brand. No comparative claims. Maintained allowlist of safe capitalised words. Phrases pruned to remove too-generic ones like 'designed for', 'genuine', 'authentic' which fire on innocent product copy. Threshold raised to 4 to absorb proper-noun edge cases (place names, etc.) without false IP_HOLD."
  },

  "forbidden_phrases": [
    "compatible with",
    "replacement for",
    "alternative to",
    "equivalent to",
    "compare to",
    "compares to",
    "comparable to",
    "approved by",
    "recommended by",
    "works with",
    "better than",
    "as good as",
    "same as",
    "replaces",
    "oem approved",
    "factory approved",
    "manufacturer recommended",
    "manufacturer approved",
    "like the famous",
    "like the popular",
    "made by",
    "produced by",
    "branded",
    "trademark",
    "patented",
    "fits all",
    "universal fit"
  ],

